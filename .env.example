# =========================================================================
# INISIALISASI AWAL PROJECT "NOTES SMANGAD"
# =========================================================================
# Ikuti langkah-langkah di bawah ini jika baru pertama kali clone project:
#
# 1. Pastikan Node.js dan MariaDB/MySQL sudah terinstall dan berjalan.
# 2. Buka terminal di folder project ini, lalu jalankan:
#    npm install
# 3. Buat database baru (kosong) di MariaDB dengan nama: notes_smangad
# 4. Duplikat file ini (.env.example) dan ubah nama hasil duplikatnya menjadi .env
# 5. Buka file .env yang baru dibuat, lalu sesuaikan nilai DATABASE_URL dan NEXTAUTH_SECRET.
# 6. Sinkronkan struktur tabel ke database MariaDB dengan perintah:
#    npx prisma db push
# 7. Buat Prisma Client agar bisa dibaca oleh Next.js:
#    npx prisma generate
# 8. Jalankan server development:
#    npm run dev
# 9. Buka browser ke http://localhost:3000/register untuk mendaftarkan akun admin pertama.
# =========================================================================

# -------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (MariaDB / MySQL)
# -------------------------------------------------------------------------
# Jika MariaDB Anda tidak memakai password, biarkan kosong 
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=notes_smangad
DB_PORT=3306

# -------------------------------------------------------------------------
# 2. NEXTAUTH CONFIGURATION
# -------------------------------------------------------------------------
# URL utama aplikasi (Wajib diset ke localhost:3000 saat development lokal)
NEXTAUTH_URL="http://localhost:3000"

# Kunci rahasia untuk mengenkripsi JWT Session. 
# HARUS diganti dengan string acak yang panjang saat di-deploy ke Production!
# (Bisa generate string acak di terminal linux dengan: openssl rand -base64 32)
NEXTAUTH_SECRET="smangadnumbawan"