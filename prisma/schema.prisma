generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Journal {
  id          Int      @id @default(autoincrement())
  tanggal     DateTime
  nama        String
  deskripsi   String
  imageUrl    String?  
  createdAt   DateTime @default(now())
}